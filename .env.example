# AQWELIA — Variables d'environnement
# Copiez ce fichier en .env et adaptez si besoin

# Base de données PostgreSQL (production/mobile)
# Format: postgresql://user:password@host:port/dbname?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/aqwelia?schema=public

# Pour dev local sans Postgres, vous pouvez utiliser SQLite en décommentant:
# DATABASE_URL=file:./db/dev.db

# Authentification (NextAuth.js)
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# OAuth Social — Google (https://console.cloud.google.com/apis/credentials)
# Create an OAuth 2.0 Client ID → Authorized redirect URI:
#   https://YOUR_DOMAIN/api/auth/callback/google
# (In dev: http://localhost:3000/api/auth/callback/google)
# Leave blank to disable Google login (Credentials-only fallback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Social — Apple Sign-In (https://developer.apple.com/account/resources/identifiers/list)
# Required by the App Store whenever any other social login is offered.
# 1. Create a Sign In with Apple Service ID (APPLE_CLIENT_ID).
# 2. Register a Key (Key ID = APPLE_KEY_ID) and download the .p8 file. The
#    APPLE_PRIVATE_KEY value should be the full PEM content of that file
#    (header, base64 body, footer). NextAuth accepts the raw multi-line PEM;
#    you can also JSON-encode it as a single line with escaped newlines if
#    your env loader requires it.
# 3. Configure the Return URL: https://YOUR_DOMAIN/api/auth/callback/apple
# Leave all 4 blank to disable Apple login.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# PostHog Analytics (https://us.posthog.com or self-hosted)
# Create a project → Project Settings → API keys. The public key (NEXT_PUBLIC_*)
# is exposed to the browser; the secret server key (POSTHOG_KEY) is used by
# the Node route handlers (trackEventServer).
# Leave blank to disable analytics in dev (no-op, no network calls).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
POSTHOG_KEY=
POSTHOG_HOST=https://us.posthog.com

# Admin emails (CSV) — restricts GET /api/care/notify, /api/pro/early-access,
# and /api/partners/apply to a known list of admins. Leave unset to allow any
# authenticated user (loose admin check — fine for dev).
# ADMIN_EMAILS=founder@aqwelia.app,ops@aqwelia.app

# API backend (pour client mobile Capacitor)
# En dev: relatif. En prod mobile: URL HTTPS du backend déployé
NEXT_PUBLIC_API_BASE_URL=

# Stripe (web subscriptions)
# Dashboard: https://dashboard.stripe.com/products → create 4 recurring prices
# (premium_monthly, premium_yearly, expert_monthly, expert_yearly)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_EXPERT_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_EXPERT_YEARLY=price_xxxxxxxxxxxxx

# RevenueCat (mobile IAP — iOS + Android)
# Dashboard: https://app.revenuecat.com → AQWELIA project → API Keys
# - Public app keys (NEXT_PUBLIC_*) are embedded in the native app and used
#   by `src/lib/billing/revenuecat.ts` to configure the RC SDK at runtime.
# - REVENUECAT_API_KEY is the secret server-side key (used for REST API calls
#   from the backend — grant/refund, user lookup, etc.).
# - REVENUECAT_WEBHOOK_SECRET is the bearer token RC sends in the
#   `Authorization` header of every webhook call. Configured in the RC
#   dashboard under Project Settings → Integrations → Webhook.
NEXT_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxx
NEXT_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxx
REVENUECAT_API_KEY=sk_xxxxxxxxxxxxx
REVENUECAT_WEBHOOK_SECRET=rc_wh_xxxxxxxxxxxxx

# Z.ai SDK (déjà configuré via le système, mais ajouté pour clarté)
# Z_AI_API_KEY=

# Météo (optionnel - proxy si wttr.in bloqué)
WTTR_IN_BASE_URL=https://wttr.in

# NVIDIA NIM (IA — vision + chat)
# Get a free API key at https://build.nvidia.com (1000 free credits)
# Chat: GLM-5.2 (flagship LLM by Z.ai on NVIDIA NIM)
#   https://build.nvidia.com/z-ai/glm-5.2
# Vision: Llama 3.2 90B Vision (multimodal — required for photo diagnostic)
#   https://build.nvidia.com/explore/vision
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl
NVIDIA_CHAT_MODEL=z-ai/glm-5.2

# SMTP (transactional emails — welcome, lead notifications, trial ending)
# If unset, every email send is a no-op (logs to stdout). Safe for dev/CI.
# Recommended providers: Brevo (smtp-brevo.com:587), Mailgun, Amazon SES.
# Format of EMAIL_FROM: "Display Name <email@domain>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AQWELIA <contact@aqwelia.app>
# Optional: override the team notification address (default: contact@aqwelia.app)
# Used for Pro early-access + Care launch leads.
EMAIL_TO_TEAM=contact@aqwelia.app

# Admin emails (comma-separated, optional)
# Restricts GET /api/pro/early-access and GET /api/care/notify to these emails.
# If unset, any authenticated user can list (loose admin gate).
ADMIN_EMAILS=
