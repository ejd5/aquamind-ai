# AQWELIA — Environment configuration template
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ─── DATABASE ───────────────────────────────────────────────────────────────
# SQLite for dev, PostgreSQL for prod
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── AUTH (NextAuth.js v4) ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
# Trust X-Forwarded-Host/Proto headers (proxy/preview). Supported since next-auth v4.24.
AUTH_TRUST_HOST=true

# ─── STRIPE (TEST MODE) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PRICE_OASIS_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_OASIS_YEARLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_WELLNESS_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_WELLNESS_YEARLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_SPA365_MONTHLY=price_xxxxxxxxxxxxx

# ─── NVIDIA NIM (IA — vision + chat) ────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl
NVIDIA_CHAT_MODEL=z-ai/glm-5.2

# ─── WEATHER ────────────────────────────────────────────────────────────────
WTTR_IN_BASE_URL=https://wttr.in

# ─── POSTHOG (optional in dev) ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── OAUTH (optional — Google/Apple) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─── REVENUECAT (mobile — optional) ─────────────────────────────────────────
NEXT_PUBLIC_REVENUECAT_IOS_KEY=
NEXT_PUBLIC_REVENUECAT_ANDROID_KEY=
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

# ─── EMAIL (optional in dev) ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AQWELIA <noreply@aqwelia.app>

# ─── SITE URL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
