// AQWELIA — Schéma de données complet pour copilote piscine
// Provider: PostgreSQL for staging and production.
// Generated from prisma/schema.prisma — do not edit manually.
// Auth: NextAuth.js (JWT strategy) — User + Account models, pas de Session

generator client {
  provider = "prisma-client-js"
  output   = "../../generated/client-postgresql"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────────────────
// AUTHENTIFICATION (NextAuth.js)
// ───────────────────────────────────────────────────────────────────────────

// Utilisateur AQWELIA (propriétaire de toutes les données ci-dessous)
model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String?
  phone            String?
  role             String   @default("user") // user | pro | business | admin
  locale           String   @default("fr")
  country          String   @default("FR")
  timezone         String   @default("Europe/Paris")
  consentMarketing Boolean  @default(false)
  consentAnalytics Boolean  @default(true)
  consentEmail     Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations vers les données possédées
  poolProfiles             PoolProfile[]
  waterTests               WaterTest[]
  photoDiagnostics         PhotoDiagnostic[]
  equipment                Equipment[]
  inventory                ProductInventory[]
  chatMessages             ChatMessage[]
  maintenanceTasks         MaintenanceTask[]
  poolDesigns              PoolDesign[]
  reminders                Reminder[]
  guideViews               GuideView[]
  subscriptions            Subscription[]
  analyticsEvents          AnalyticsEvent[]
  recommendationExecutions RecommendationExecution[]
  recommendationOutcomes   RecommendationOutcome[]
  brainFeedback            BrainFeedback[]

  // AQWELIA Pro — clients gérés par ce pro (Pro MVP)
  proClients ProClient[]

  // AQWELIA Family — pools owned by this user
  ownedPoolShares  PoolShare[] @relation("PoolSharesOwnedBy")
  // AQWELIA Family — pools shared WITH this user
  sharedPoolShares PoolShare[] @relation("PoolSharesSharedWith")

  // AQWELIA Home (IoT) — sensors owned by this user
  iotSensors IotSensor[]

  // AQWELIA Growth OS — organizations owned by this user
  ownedOrganizations      Organization[]       @relation("OwnedOrganizations")
  // AQWELIA Growth OS — organizations this user is a member of
  organizationMemberships OrganizationMember[]

  // OAuth / comptes liés (NextAuth future-proof)
  accounts Account[]
}

// Compte OAuth (Google, Apple, etc.) pour NextAuth — structure simple
// Permet d'ajouter l'auth sociale plus tard sans casser le schéma
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ───────────────────────────────────────────────────────────────────────────
// DONNÉES UTILISATEUR (toutes liées à User via userId)
// ───────────────────────────────────────────────────────────────────────────

// Profil de la piscine (obligatoire pour conseils personnalisés)
model PoolProfile {
  id            String   @id @default(cuid())
  userId        String
  name          String   @default("Ma piscine")
  volume        Float // volume en m³
  unit          String   @default("m3") // m3 | gal
  shape         String   @default("rectangular") // rectangular | round | oval | free
  surfaceType   String   @default("liner") // liner | shell | concrete | tile
  treatmentType String   @default("chlorine") // chlorine | salt | bromine | active_oxygen | uv | other
  filterType    String   @default("sand") // sand | cartridge | glass | diatom
  pumpType      String? // marque/modèle pompe
  saltSystem    Boolean  @default(false)
  region        String? // région / climat
  sunExposure   String   @default("medium") // low | medium | high
  covered       Boolean  @default(false)
  waterBodyType String   @default("pool") // pool | spa | both
  spaSeats      Int? // nombre de places assises (spa)
  spaTempTarget Int? // température cible °C (spa)
  spaUsageFreq  String? // occasional | regular | intensive (spa)
  spaBrand      String? // marque du spa
  usageLevel    String   @default("medium") // low | medium | high
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // AQWELIA Family — shares granted on this pool (owner-side)
  shares                   PoolShare[]
  waterTests               WaterTest[]
  photoDiagnostics         PhotoDiagnostic[]
  recommendationExecutions RecommendationExecution[]
  recommendationOutcomes   RecommendationOutcome[]
  brainFeedback            BrainFeedback[]

  @@index([userId])
}

// Test / mesure d'eau complet
model WaterTest {
  id               String   @id @default(cuid())
  userId           String
  poolId           String?
  ph               Float
  freeChlorine     Float?
  totalChlorine    Float?
  combinedChlorine Float?
  alkalinity       Float? // TAC mg/L
  calciumHardness  Float? // TH mg/L
  cyanuricAcid     Float? // CYA mg/L
  salt             Float? // g/L
  bromine          Float?
  phosphates       Float? // mg/L
  temperature      Float? // °C
  source           String   @default("manual") // manual | strip_photo | device | imported
  note             String?
  status           String   @default("ok") // ok | warning | critical
  clearWaterIndex  Int      @default(80) // 0-100
  swimSafety       String   @default("allowed") // allowed | avoid | forbidden | unknown
  lsi              Float? // Langelier Saturation Index
  createdAt        DateTime @default(now())

  actionPlans      ActionPlan[]
  baselineOutcomes RecommendationOutcome[] @relation("BrainBaselineTest")
  followupOutcome  RecommendationOutcome?  @relation("BrainFollowupTest")
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool             PoolProfile?            @relation(fields: [poolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([poolId])
  @@index([poolId, createdAt])
}

// Diagnostic photo IA (VLM structuré)
model PhotoDiagnostic {
  id                  String   @id @default(cuid())
  userId              String
  poolId              String?
  type                String // water | wall | filter | electrolyzer | pump | strip | product | equipment
  imageUrl            String
  detectedIssues      String // JSON string array
  probableIssues      String // JSON string array
  confidence          Float    @default(0)
  aiSummary           String
  missingData         String // JSON string array
  recommendedNextStep String?
  safetyWarnings      String // JSON string array
  createdAt           DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool PoolProfile? @relation(fields: [poolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([poolId])
}

// Plan d'action généré (déterministe + IA)
// Pas de userId direct — hérite du userId du WaterTest parent (cascade)
model ActionPlan {
  id                     String   @id @default(cuid())
  waterTestId            String
  diagnosis              String
  severity               String   @default("low") // low | medium | high | urgent
  confidence             Float    @default(0.8)
  immediateActions       String // JSON string array (ordonnées)
  chemicalDosages        String // JSON string array
  filtrationHours        Float    @default(0)
  retestInHours          Float    @default(24)
  swimSafety             String   @default("unknown")
  doNotDo                String // JSON string array
  estimatedCost          String?
  whenToCallProfessional String?
  createdAt              DateTime @default(now())

  waterTest  WaterTest                 @relation(fields: [waterTestId], references: [id], onDelete: Cascade)
  executions RecommendationExecution[]
  outcome    RecommendationOutcome?
}

model RecommendationExecution {
  id            String      @id @default(cuid())
  userId        String
  poolId        String
  actionPlanId  String
  actionIndex   Int
  actionLabel   String
  status        String      @default("planned")
  productName   String?
  plannedDosage String?
  actualDosage  Float?
  actualUnit    String?
  note          String?
  executedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool          PoolProfile @relation(fields: [poolId], references: [id], onDelete: Cascade)
  actionPlan    ActionPlan  @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)

  @@unique([actionPlanId, actionIndex])
  @@index([userId])
  @@index([poolId, createdAt])
  @@index([status])
}

model RecommendationOutcome {
  id                    String      @id @default(cuid())
  userId                String
  poolId                String
  actionPlanId          String      @unique
  baselineWaterTestId   String
  followupWaterTestId   String?     @unique
  status                String      @default("awaiting_retest")
  clearWaterIndexBefore Int?
  clearWaterIndexAfter  Int?
  userRating            Int?
  userFeedback          String?
  evaluatedAt           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool                  PoolProfile @relation(fields: [poolId], references: [id], onDelete: Cascade)
  actionPlan            ActionPlan  @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  baselineWaterTest     WaterTest   @relation("BrainBaselineTest", fields: [baselineWaterTestId], references: [id], onDelete: Cascade)
  followupWaterTest     WaterTest?  @relation("BrainFollowupTest", fields: [followupWaterTestId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([poolId, createdAt])
  @@index([status])
}

model BrainFeedback {
  id          String       @id @default(cuid())
  userId      String
  poolId      String?
  contextType String
  contextId   String?
  rating      Int?
  helpful     Boolean?
  message     String?
  status      String       @default("new")
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool        PoolProfile? @relation(fields: [poolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([poolId])
  @@index([contextType, contextId])
  @@index([status, createdAt])
}

model KnowledgeArticle {
  id             String              @id @default(cuid())
  slug           String              @unique
  category       String
  audience       String              @default("all")
  riskLevel      String              @default("standard")
  status         String              @default("draft")
  currentVersion Int                 @default(1)
  tags           String?
  relatedSlugs   String?
  publishedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  revisions      KnowledgeRevision[]

  @@index([status, audience])
  @@index([category])
}

model KnowledgeRevision {
  id         String           @id @default(cuid())
  articleId  String
  version    Int
  locale     String           @default("fr")
  title      String
  summary    String?
  content    String
  sources    String?
  changeNote String?
  createdBy  String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime         @default(now())
  article    KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, version, locale])
  @@index([articleId, locale])
  @@index([reviewedAt])
}

model BrainEventOutbox {
  id             String    @id @default(cuid())
  idempotencyKey String    @unique
  type           String
  aggregateType  String
  aggregateId    String
  payload        String?
  status         String    @default("pending")
  attempts       Int       @default(0)
  nextAttemptAt  DateTime?
  lockedAt       DateTime?
  processedAt    DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@index([type, createdAt])
}

// Équipements de la piscine
model Equipment {
  id                String    @id @default(cuid())
  userId            String
  type              String // pump | filter | electrolyzer | cell | phProbe | robot | cover | heatpump | skimmer
  brand             String?
  model             String?
  installedAt       DateTime?
  lastMaintenanceAt DateTime?
  nextMaintenanceAt DateTime?
  photoUrl          String?
  status            String    @default("ok") // ok | warning | issue
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Inventaire produits
model ProductInventory {
  id            String   @id @default(cuid())
  userId        String
  productName   String
  category      String // ph_minus | ph_plus | chlorine_slow | chlorine_shock | salt | alkalinity_plus | stabilizer | flocculant | anti_algae | filter_cleaner | other
  concentration Float?
  quantity      Float
  unit          String   @default("kg") // kg | L | tablet
  price         Float?
  instructions  String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Historique conversations assistant
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String // user | assistant
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Tâches de maintenance (liées à un équipement optionnellement)
model MaintenanceTask {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String    @default("cleaning")
  priority    String    @default("medium")
  status      String    @default("pending")
  dueDate     DateTime?
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Designs générés (studio IA)
model PoolDesign {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  imageUrl  String
  style     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Rappels intelligents (générés et manuels)
model Reminder {
  id        String    @id @default(cuid())
  userId    String
  type      String // test_water, retest_after_product, after_storm, filter_clean, cell_clean, ...
  title     String
  detail    String
  action    String
  priority  String    @default("medium") // low, medium, high, urgent
  source    String    @default("schedule") // weather, test_history, inventory, equipment, schedule, manual
  dueAt     DateTime?
  done      Boolean   @default(false)
  doneAt    DateTime?
  snoozed   Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Vue de guide (tracking analytics + recommendation)
model GuideView {
  id       String   @id @default(cuid())
  userId   String
  guideId  String
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Abonnement freemium
// P0-B: added status, store, stripeCustomerId, stripeSubscriptionId,
// cancelAt, trialEndsAt, currentPeriodStart, currentPeriodEnd.
// The `active` field is kept for backward compat but is derived from `status`.
model Subscription {
  id                     String    @id @default(cuid())
  userId                 String
  plan                   String    @default("decouverte") // decouverte, oasis, wellness, spa365
  status                 String    @default("inactive") // inactive, trialing, active, past_due, canceled, expired, grace_period
  duration               String? // week, month, halfyear, year
  store                  String? // web, ios, android
  startedAt              DateTime  @default(now())
  expiresAt              DateTime?
  cancelAt               DateTime?
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  stripeCustomerId       String?
  stripeSubscriptionId   String?   @unique
  // P0-B: stable provider identity for finding inactive subscriptions
  providerSubscriptionId String?   @unique // RC original_transaction_id or Stripe sub ID
  // P0-B: out-of-order event protection
  lastProviderEventId    String?
  lastProviderEventAt    DateTime?
  active                 Boolean   @default(false) // legacy — derived from status

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// P0-B: Billing event log — idempotency for webhooks.
// Uses composite unique [source, eventId] so Stripe and RC can have
// overlapping event IDs without collision.
// Retry/crash recovery: attemptCount, processingStartedAt, nextRetryAt.
model BillingEvent {
  id                  String    @id @default(cuid())
  eventId             String // Stripe event.id or RC event.id
  source              String // stripe | revenuecat
  eventType           String // checkout.session.completed, CANCELLATION, etc.
  userId              String?
  payload             String? // Redacted JSON (no card numbers, secrets)
  result              String    @default("processing") // processing | processed | failed | ignored
  ignoredReason       String? // unknown_product | unknown_price | event_type_not_supported | missing_user_mapping | no_subscription_link
  errorMessage        String?
  attemptCount        Int       @default(0)
  processingStartedAt DateTime?
  processingToken     String?
  processedAt         DateTime?
  nextRetryAt         DateTime?
  createdAt           DateTime  @default(now())

  @@unique([source, eventId])
  @@index([source, eventType])
  @@index([userId])
  @@index([result])
  @@index([nextRetryAt])
}

// Événements analytics (funnel, rétention)
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  event     String // first_scan, first_test, first_plan, guide_opened, video_viewed, paywall_viewed, ...
  props     String? // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA PRO — Early Access leads (marketing funnel)
// ───────────────────────────────────────────────────────────────────────────

// Soumissions du formulaire /pro/early-access (piscinistes pro intéressés)
model EarlyAccessLead {
  id          String   @id @default(cuid())
  companyName String
  email       String   @unique
  phone       String?
  poolCount   Int      @default(0)
  techCount   Int      @default(1)
  message     String?
  createdAt   DateTime @default(now())
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA CARE — Notifications de lancement (marketing funnel)
// ───────────────────────────────────────────────────────────────────────────

// Soumissions du formulaire /care (particuliers / pros intéressés par Care)
model CareNotification {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA PARTNERS — Candidatures partenaires (marketing funnel)
// ───────────────────────────────────────────────────────────────────────────

// Candidatures soumises via /partenaires/fournisseurs ou /partenaires/piscinistes
// (2 types: "fournisseur" pour AQWELIA Care, "pisciniste" pour affiliation Pro)
model PartnerApplication {
  id          String   @id @default(cuid())
  companyName String
  email       String
  type        String // fournisseur | pisciniste
  products    String? // description des produits / services (fournisseurs)
  message     String?
  createdAt   DateTime @default(now())

  @@index([type])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA — Messages de contact (page /contact, public)
// ───────────────────────────────────────────────────────────────────────────

// Soumissions du formulaire /contact (questions, demandes support, partenariats)
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String // general | support | partnership | press | other
  message   String
  // Statut de traitement interne (back-office)
  status    String   @default("new") // new | read | replied | archived
  // Optionnel : userId si l'utilisateur était connecté lors de l'envoi
  userId    String?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA PRO — APP métier piscinistes (MVP)
// ───────────────────────────────────────────────────────────────────────────
// Un "pro" est un User AQWELIA Pro authentifié. Chaque pro gère ses propres
// ProClient (des clients IRL — particuliers ou entreprises), chacun pouvant
// avoir plusieurs ProPool (piscine, spa, both). Sur chaque bassin le pro
// enregistre des ProWaterTest (analyses d'eau) et des ProIntervention
// (visites de maintenance, réparations, ouvertures, fermetures, urgences).
//
// Toutes les requêtes API filtrent par `proUserId = session.user.id` afin
// qu'un pro ne puisse jamais accéder aux données d'un autre pro.

// Un client du pisciniste (pas un utilisateur AQWELIA — un client IRL)
model ProClient {
  id        String   @id @default(cuid())
  proUserId String // l'utilisateur AQWELIA Pro qui gère ce client
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?
  city      String?
  zipCode   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pools         ProPool[]
  interventions ProIntervention[]

  user User @relation(fields: [proUserId], references: [id], onDelete: Cascade)

  @@index([proUserId])
  @@index([lastName])
  @@index([firstName])
}

// Un bassin géré par le pro pour un client
model ProPool {
  id            String   @id @default(cuid())
  proClientId   String
  name          String // "Piscine principale", "Spa"
  type          String   @default("pool") // pool | spa | both
  volume        Float?
  unit          String   @default("m3")
  shape         String?
  surface       String? // liner, tile, concrete, etc.
  treatmentType String? // chlorine, salt, bromine, etc.
  saltSystem    Boolean  @default(false)
  filterType    String? // sand, cartridge, etc.
  address       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client        ProClient         @relation(fields: [proClientId], references: [id], onDelete: Cascade)
  interventions ProIntervention[]
  waterTests    ProWaterTest[]

  @@index([proClientId])
}

// Un test d'eau effectué par le pro sur un bassin
model ProWaterTest {
  id               String   @id @default(cuid())
  proPoolId        String
  ph               Float?
  freeChlorine     Float?
  totalChlorine    Float?
  combinedChlorine Float?
  alkalinity       Float?
  calciumHardness  Float?
  cyanuricAcid     Float?
  salt             Float?
  phosphates       Float?
  temperature      Float?
  clearWaterIndex  Int?
  notes            String?
  testedAt         DateTime @default(now())

  pool ProPool @relation(fields: [proPoolId], references: [id], onDelete: Cascade)

  @@index([proPoolId])
  @@index([testedAt])
}

// Une intervention du pro sur un bassin
model ProIntervention {
  id           String    @id @default(cuid())
  proClientId  String
  proPoolId    String?
  technicianId String? // User id du technicien
  type         String    @default("maintenance") // maintenance | repair | opening | closing | emergency
  status       String    @default("scheduled") // scheduled | in_progress | completed | cancelled
  scheduledAt  DateTime
  completedAt  DateTime?
  duration     Int? // minutes
  notes        String?
  photos       String? // JSON array of URLs (before/after)
  actions      String? // JSON array of actions performed
  productsUsed String? // JSON array of products used
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client ProClient @relation(fields: [proClientId], references: [id], onDelete: Cascade)
  pool   ProPool?  @relation(fields: [proPoolId], references: [id], onDelete: SetNull)

  @@index([proClientId])
  @@index([proPoolId])
  @@index([status])
  @@index([scheduledAt])
  @@index([technicianId])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA FAMILY — Partage de piscine familial (multi-user read/write access)
// ───────────────────────────────────────────────────────────────────────────
// A PoolShare grants another AQWELIA user access to a pool owned by someone
// else. Roles: owner (implicit, never stored), co_manager (can test/add data),
// viewer (read-only). Cascade-deleted when the pool OR either user is deleted.

model PoolShare {
  id           String   @id @default(cuid())
  poolId       String // PoolProfile id
  sharedWithId String // User id of the invited user
  role         String   @default("viewer") // owner | co_manager | viewer
  invitedBy    String // User id of the owner who sent the invite
  createdAt    DateTime @default(now())

  pool          PoolProfile @relation(fields: [poolId], references: [id], onDelete: Cascade)
  sharedWith    User        @relation("PoolSharesSharedWith", fields: [sharedWithId], references: [id], onDelete: Cascade)
  invitedByUser User        @relation("PoolSharesOwnedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([poolId, sharedWithId])
  @@index([poolId])
  @@index([sharedWithId])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA CARE — Marketplace produits & commandes (P8-BUSINESS-CARE)
// ───────────────────────────────────────────────────────────────────────────
// Catalogue de consommables et petits accessoires (bandelettes, cartouches,
// joints, doseurs, correcteurs chimiques UE…). Catégories codées par couleur
// (green | orange | red) pour guider la réglementation et l'affichage.
// Les produits réglementés (red, biocides) sont marqués `regulated=true` et
// `active=false` — non vendus directement, redirigés vers un partenaire.

model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  brand        String?
  category     String // green | orange | red
  subcategory  String?
  description  String?
  price        Float
  currency     String   @default("EUR")
  unit         String // kg | L | ml | tablet | piece
  stockQty     Int      @default(0)
  imageUrl     String?
  regulated    Boolean  @default(false)
  hazardLevel  String? // none | low | medium | high
  sdsUrl       String? // Safety Data Sheet
  instructions String?
  warnings     String?
  active       Boolean  @default(true)
  country      String   @default("FR")
  supplierId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  nameKey   String
  icon      String?
  color     String? // green | orange | red
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Cart {
  id        String   @id @default(cuid())
  userId    String
  items     String // JSON array
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  items     String // JSON array
  subtotal  Float
  tax       Float
  shipping  Float
  total     Float
  currency  String   @default("EUR")
  status    String   @default("pending") // pending | paid | shipped | delivered | cancelled
  tracking  String?
  address   String?
  city      String?
  zipCode   String?
  country   String   @default("FR")
  createdAt DateTime @default(now())
}

model Kit {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  nameKey        String
  description    String?
  descriptionKey String?
  price          Float
  currency       String   @default("EUR")
  imageUrl       String?
  items          String // JSON array of {productId, quantity}
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA HOME (IoT) — Capteurs connectés (ICO / iopool / ESPHome)
// ───────────────────────────────────────────────────────────────────────────
// Configuration of a connected water-quality sensor. Stores provider +
// credentials so the restock/automation engine can later poll the sensor API
// and inject a WaterTest. Sensitive fields (apiKey) are kept server-side only.

model IotSensor {
  id         String    @id @default(cuid())
  userId     String // owner of the sensor config
  poolId     String? // optional linked pool (null = global)
  provider   String // ico | iopool | esphome | homeassistant
  label      String // user-facing name
  deviceId   String? // external id (ICO serial, iopool EcO id, HA entity id)
  apiUrl     String? // base URL (esphome / HA / custom)
  apiKey     String? // encrypted/secret token (server-side only)
  config     String? // JSON blob with provider-specific options (refresh interval, MQTT topic…)
  status     String    @default("disconnected") // connected | disconnected | error
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([poolId])
}

// ───────────────────────────────────────────────────────────────────────────
// P8-INFRA — Consent tracking (RGPD proof-of-consent ledger)
// ───────────────────────────────────────────────────────────────────────────
// One row per consent event (grant OR withdrawal). Optional userId for logged-in
// users, optional leadId for marketing funnel leads (EarlyAccessLead,
// CareNotification, PartnerApplication, ContactMessage). The `proof` JSON
// captures the regulatory audit trail (IP, user agent, exact timestamp).

model ConsentRecord {
  id             String    @id @default(cuid())
  userId         String?
  leadId         String?
  purpose        String // marketing | analytics | email | sms | phone
  channel        String // web | app | form | widget
  source         String? // url or form id
  wordingVersion String?
  grantedAt      DateTime?
  withdrawnAt    DateTime?
  proof          String? // JSON proof (IP, user agent, timestamp)
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([leadId])
  @@index([purpose])
}

// ───────────────────────────────────────────────────────────────────────────
// P8-INFRA — Suppliers (AQWELIA Care marketplace partners)
// ───────────────────────────────────────────────────────────────────────────
// A Supplier is a B2B partner fulfilling AQWELIA Care orders. Dropshipping
// suppliers ship directly to the end customer; others go through the AQWELIA
// warehouse. `commissionRate` is the platform take (0-1). `shippingCountries`
// is a comma-separated ISO-3166-1 alpha-2 list (e.g. "FR,ES,BE").

model Supplier {
  id                String   @id @default(cuid())
  name              String
  legalName         String?
  siret             String?
  country           String   @default("FR")
  commissionRate    Float    @default(0.1)
  shippingCountries String   @default("FR")
  dropshipping      Boolean  @default(false)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
}

// ───────────────────────────────────────────────────────────────────────────
// P8-INFRA — AQWELIA Academy (Phase 12)
// ───────────────────────────────────────────────────────────────────────────
// Catalogue of e-learning courses for pool owners, pros and business users.
// `slug` is the public URL (/academy/[slug]). `titleKey` + `descriptionKey`
// point to i18n keys so the catalogue is fully localised. `content` is
// markdown rendered server-side. `level` is beginner | intermediate | expert.

model AcademyCourse {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  titleKey       String
  description    String?
  descriptionKey String?
  level          String   @default("beginner") // beginner | intermediate | expert
  duration       Int // minutes
  videoUrl       String?
  content        String? // markdown
  order          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  certifications Certification[]

  @@index([active])
  @@index([level])
}

// A user's progression + certification on a course. `status` transitions:
// in_progress → completed → expired. Certifications expire after 1 year
// (set by the API when `completedAt` is recorded).

model Certification {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  status      String    @default("in_progress") // in_progress | completed | expired
  score       Int?
  completedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  course AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA GROWTH OS — 10-agent growth engine for pool pros
// ───────────────────────────────────────────────────────────────────────────
// Organizations (pro / business / growth tiers) own Leads captured from
// multiple sources (website, widget, B2C marketplace, QR, campaigns). Each
// lead runs through a pipeline of 10 specialized AI agents:
//   offer_builder → lead_capture → qualification → diagnostic → matching →
//   appointment → nurturing → quote → attribution → compliance
// Agent runs + actions are logged for full auditability.

model Organization {
  id        String   @id @default(cuid())
  type      String   @default("pro") // pro | business | growth
  name      String
  legalName String?
  siret     String?
  vatNumber String?
  address   String?
  city      String?
  zipCode   String?
  country   String   @default("FR")
  phone     String?
  email     String?
  website   String?
  plan      String   @default("growth_starter") // growth_starter | growth_pro | performance
  status    String   @default("trial") // trial | active | suspended | cancelled
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members OrganizationMember[]
  leads   Lead[]
  owner   User                 @relation("OwnedOrganizations", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([status])
  @@index([plan])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member") // owner | admin | manager | technician | viewer
  status         String   @default("active") // active | invited | suspended | removed
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Lead {
  id             String   @id @default(cuid())
  organizationId String?
  source         String   @default("website") // website | widget | b2c | qr | campaign | partner | referral
  firstName      String
  lastName       String
  email          String
  phone          String?
  address        String?
  city           String?
  zipCode        String?
  country        String   @default("FR")
  serviceType    String? // maintenance | repair | opening | closing | emergency | spa | renovation
  poolType       String?
  poolVolume     Float?
  problem        String?
  urgency        String   @default("normal") // low | normal | high | emergency
  budget         String?
  status         String   @default("NEW") // NEW | QUALIFIED | SCORED | ASSIGNED | CONTACTED | APPOINTMENT | QUOTED | WON | LOST
  score          Int      @default(0)
  assignedTo     String?
  consent        Boolean  @default(false)
  consentSource  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  events       LeadEvent[]
  appointments Appointment[]
  quotes       Quote[]
  commissions  Commission[]
  agentRuns    AgentRun[]

  @@index([organizationId])
  @@index([status])
  @@index([source])
  @@index([assignedTo])
  @@index([createdAt])
}

model LeadEvent {
  id        String   @id @default(cuid())
  leadId    String
  type      String // created | qualified | scored | assigned | contacted | appointment_scheduled | quote_sent | etc
  actor     String? // agent type or user id
  payload   String? // JSON
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

model Appointment {
  id             String   @id @default(cuid())
  leadId         String
  organizationId String?
  assignedTo     String?
  startTime      DateTime
  endTime        DateTime
  status         String   @default("proposed") // proposed | confirmed | completed | cancelled | no_show
  notes          String?
  createdAt      DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([organizationId])
  @@index([startTime])
  @@index([status])
}

model Quote {
  id             String    @id @default(cuid())
  leadId         String
  organizationId String?
  items          String // JSON array
  total          Float
  currency       String    @default("EUR")
  status         String    @default("draft") // draft | sent | accepted | rejected | expired
  sentAt         DateTime?
  acceptedAt     DateTime?
  validUntil     DateTime?
  createdAt      DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([organizationId])
  @@index([status])
}

model Commission {
  id             String    @id @default(cuid())
  leadId         String
  organizationId String?
  invoiceId      String?
  rate           Float
  amount         Float
  minimum        Float     @default(25)
  maximum        Float     @default(150)
  status         String    @default("pending") // pending | due | paid | disputed | refunded
  disputeWindow  DateTime?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([organizationId])
  @@index([status])
}

model AgentRun {
  id             String    @id @default(cuid())
  agentType      String // offer_builder | lead_capture | qualification | diagnostic | matching | appointment | nurturing | quote | attribution | compliance
  organizationId String?
  userId         String?
  leadId         String?
  objective      String
  input          String? // JSON
  output         String? // JSON
  confidence     Float     @default(0)
  status         String    @default("running") // running | completed | failed | escalated
  cost           Float     @default(0)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  lead    Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  actions AgentAction[]

  @@index([agentType])
  @@index([organizationId])
  @@index([leadId])
  @@index([status])
}

model AgentAction {
  id               String   @id @default(cuid())
  agentRunId       String
  tool             String
  action           String
  approvalRequired Boolean  @default(true)
  approvedBy       String?
  result           String? // JSON
  createdAt        DateTime @default(now())

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId])
  @@index([approvedBy])
}
