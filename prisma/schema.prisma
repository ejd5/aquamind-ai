// AQWELIA — Schéma de données complet pour copilote piscine
// Provider: SQLite for local/dev (file: URL in `.env` DATABASE_URL).
// For production, switch back to PostgreSQL by editing this file (or use
// the `prismaSchemaFolder` + multi-schema feature) and update DATABASE_URL.
// Auth: NextAuth.js (JWT strategy) — User + Account models, pas de Session

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // P0-FIX Bug 6: was `postgresql`, but `.env` DATABASE_URL points to a
  // SQLite `file:` URL — mismatch caused Prisma to refuse any DB call at
  // runtime. Switched to sqlite for dev; flip back to `postgresql` for
  // production deployments (with a matching `DATABASE_URL=postgresql://...`).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────────────────
// AUTHENTIFICATION (NextAuth.js)
// ───────────────────────────────────────────────────────────────────────────

// Utilisateur AQWELIA (propriétaire de toutes les données ci-dessous)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations vers les données possédées
  poolProfiles     PoolProfile[]
  waterTests       WaterTest[]
  photoDiagnostics PhotoDiagnostic[]
  equipment        Equipment[]
  inventory        ProductInventory[]
  chatMessages     ChatMessage[]
  maintenanceTasks MaintenanceTask[]
  poolDesigns      PoolDesign[]
  reminders        Reminder[]
  guideViews       GuideView[]
  subscriptions    Subscription[]
  analyticsEvents  AnalyticsEvent[]

  // AQWELIA Pro — clients gérés par ce pro (Pro MVP)
  proClients       ProClient[]

  // AQWELIA Family — pools owned by this user
  ownedPoolShares  PoolShare[]  @relation("PoolSharesOwnedBy")
  // AQWELIA Family — pools shared WITH this user
  sharedPoolShares PoolShare[]  @relation("PoolSharesSharedWith")

  // AQWELIA Home (IoT) — sensors owned by this user
  iotSensors       IotSensor[]

  // OAuth / comptes liés (NextAuth future-proof)
  accounts Account[]
}

// Compte OAuth (Google, Apple, etc.) pour NextAuth — structure simple
// Permet d'ajouter l'auth sociale plus tard sans casser le schéma
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ───────────────────────────────────────────────────────────────────────────
// DONNÉES UTILISATEUR (toutes liées à User via userId)
// ───────────────────────────────────────────────────────────────────────────

// Profil de la piscine (obligatoire pour conseils personnalisés)
model PoolProfile {
  id            String   @id @default(cuid())
  userId        String
  name          String   @default("Ma piscine")
  volume        Float // volume en m³
  unit          String   @default("m3") // m3 | gal
  shape         String   @default("rectangular") // rectangular | round | oval | free
  surfaceType   String   @default("liner") // liner | shell | concrete | tile
  treatmentType String   @default("chlorine") // chlorine | salt | bromine | active_oxygen | uv | other
  filterType    String   @default("sand") // sand | cartridge | glass | diatom
  pumpType      String? // marque/modèle pompe
  saltSystem    Boolean  @default(false)
  region        String? // région / climat
  sunExposure   String   @default("medium") // low | medium | high
  covered       Boolean  @default(false)
  waterBodyType String   @default("pool") // pool | spa | both
  spaSeats      Int? // nombre de places assises (spa)
  spaTempTarget Int? // température cible °C (spa)
  spaUsageFreq  String? // occasional | regular | intensive (spa)
  spaBrand      String? // marque du spa
  usageLevel    String   @default("medium") // low | medium | high
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // AQWELIA Family — shares granted on this pool (owner-side)
  shares PoolShare[]

  @@index([userId])
}

// Test / mesure d'eau complet
model WaterTest {
  id               String   @id @default(cuid())
  userId           String
  ph               Float
  freeChlorine     Float?
  totalChlorine    Float?
  combinedChlorine Float?
  alkalinity       Float? // TAC mg/L
  calciumHardness  Float? // TH mg/L
  cyanuricAcid     Float? // CYA mg/L
  salt             Float? // g/L
  bromine          Float?
  phosphates       Float? // mg/L
  temperature      Float? // °C
  source           String   @default("manual") // manual | strip_photo | device | imported
  note             String?
  status           String   @default("ok") // ok | warning | critical
  clearWaterIndex  Int      @default(80) // 0-100
  swimSafety       String   @default("allowed") // allowed | avoid | forbidden | unknown
  lsi              Float? // Langelier Saturation Index
  createdAt        DateTime @default(now())

  actionPlans ActionPlan[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Diagnostic photo IA (VLM structuré)
model PhotoDiagnostic {
  id                  String   @id @default(cuid())
  userId              String
  type                String // water | wall | filter | electrolyzer | pump | strip | product | equipment
  imageUrl            String
  detectedIssues      String // JSON string array
  probableIssues      String // JSON string array
  confidence          Float    @default(0)
  aiSummary           String
  missingData         String // JSON string array
  recommendedNextStep String?
  safetyWarnings      String // JSON string array
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Plan d'action généré (déterministe + IA)
// Pas de userId direct — hérite du userId du WaterTest parent (cascade)
model ActionPlan {
  id                     String   @id @default(cuid())
  waterTestId            String
  diagnosis              String
  severity               String   @default("low") // low | medium | high | urgent
  confidence             Float    @default(0.8)
  immediateActions       String // JSON string array (ordonnées)
  chemicalDosages        String // JSON string array
  filtrationHours        Float    @default(0)
  retestInHours          Float    @default(24)
  swimSafety             String   @default("unknown")
  doNotDo                String // JSON string array
  estimatedCost          String?
  whenToCallProfessional String?
  createdAt              DateTime @default(now())

  waterTest WaterTest @relation(fields: [waterTestId], references: [id], onDelete: Cascade)
}

// Équipements de la piscine
model Equipment {
  id                String    @id @default(cuid())
  userId            String
  type              String // pump | filter | electrolyzer | cell | phProbe | robot | cover | heatpump | skimmer
  brand             String?
  model             String?
  installedAt       DateTime?
  lastMaintenanceAt DateTime?
  nextMaintenanceAt DateTime?
  photoUrl          String?
  status            String    @default("ok") // ok | warning | issue
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Inventaire produits
model ProductInventory {
  id            String   @id @default(cuid())
  userId        String
  productName   String
  category      String // ph_minus | ph_plus | chlorine_slow | chlorine_shock | salt | alkalinity_plus | stabilizer | flocculant | anti_algae | filter_cleaner | other
  concentration Float?
  quantity      Float
  unit          String   @default("kg") // kg | L | tablet
  price         Float?
  instructions  String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Historique conversations assistant
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String // user | assistant
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Tâches de maintenance (liées à un équipement optionnellement)
model MaintenanceTask {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String    @default("cleaning")
  priority    String    @default("medium")
  status      String    @default("pending")
  dueDate     DateTime?
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Designs générés (studio IA)
model PoolDesign {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  imageUrl  String
  style     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Rappels intelligents (générés et manuels)
model Reminder {
  id        String    @id @default(cuid())
  userId    String
  type      String // test_water, retest_after_product, after_storm, filter_clean, cell_clean, ...
  title     String
  detail    String
  action    String
  priority  String    @default("medium") // low, medium, high, urgent
  source    String    @default("schedule") // weather, test_history, inventory, equipment, schedule, manual
  dueAt     DateTime?
  done      Boolean   @default(false)
  doneAt    DateTime?
  snoozed   Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Vue de guide (tracking analytics + recommendation)
model GuideView {
  id       String   @id @default(cuid())
  userId   String
  guideId  String
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Abonnement freemium
model Subscription {
  id        String    @id @default(cuid())
  userId    String
  plan      String    @default("decouverte") // decouverte, oasis, wellness
  duration  String? // week, month, halfyear, year
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  active    Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Événements analytics (funnel, rétention)
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  event     String // first_scan, first_test, first_plan, guide_opened, video_viewed, paywall_viewed, ...
  props     String? // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA PRO — Early Access leads (marketing funnel)
// ───────────────────────────────────────────────────────────────────────────

// Soumissions du formulaire /pro/early-access (piscinistes pro intéressés)
model EarlyAccessLead {
  id          String   @id @default(cuid())
  companyName String
  email       String   @unique
  phone       String?
  poolCount   Int      @default(0)
  techCount   Int      @default(1)
  message     String?
  createdAt   DateTime @default(now())
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA CARE — Notifications de lancement (marketing funnel)
// ───────────────────────────────────────────────────────────────────────────

// Soumissions du formulaire /care (particuliers / pros intéressés par Care)
model CareNotification {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA PARTNERS — Candidatures partenaires (marketing funnel)
// ───────────────────────────────────────────────────────────────────────────

// Candidatures soumises via /partenaires/fournisseurs ou /partenaires/piscinistes
// (2 types: "fournisseur" pour AQWELIA Care, "pisciniste" pour affiliation Pro)
model PartnerApplication {
  id          String   @id @default(cuid())
  companyName String
  email       String
  type        String // fournisseur | pisciniste
  products    String? // description des produits / services (fournisseurs)
  message     String?
  createdAt   DateTime @default(now())

  @@index([type])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA — Messages de contact (page /contact, public)
// ───────────────────────────────────────────────────────────────────────────

// Soumissions du formulaire /contact (questions, demandes support, partenariats)
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String   // general | support | partnership | press | other
  message   String
  // Statut de traitement interne (back-office)
  status    String   @default("new") // new | read | replied | archived
  // Optionnel : userId si l'utilisateur était connecté lors de l'envoi
  userId    String?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA PRO — APP métier piscinistes (MVP)
// ───────────────────────────────────────────────────────────────────────────
// Un "pro" est un User AQWELIA Pro authentifié. Chaque pro gère ses propres
// ProClient (des clients IRL — particuliers ou entreprises), chacun pouvant
// avoir plusieurs ProPool (piscine, spa, both). Sur chaque bassin le pro
// enregistre des ProWaterTest (analyses d'eau) et des ProIntervention
// (visites de maintenance, réparations, ouvertures, fermetures, urgences).
//
// Toutes les requêtes API filtrent par `proUserId = session.user.id` afin
// qu'un pro ne puisse jamais accéder aux données d'un autre pro.

// Un client du pisciniste (pas un utilisateur AQWELIA — un client IRL)
model ProClient {
  id          String   @id @default(cuid())
  proUserId   String   // l'utilisateur AQWELIA Pro qui gère ce client
  firstName   String
  lastName    String
  email       String?
  phone       String?
  address     String?
  city        String?
  zipCode     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pools         ProPool[]
  interventions ProIntervention[]

  user User @relation(fields: [proUserId], references: [id], onDelete: Cascade)

  @@index([proUserId])
  @@index([lastName])
  @@index([firstName])
}

// Un bassin géré par le pro pour un client
model ProPool {
  id          String   @id @default(cuid())
  proClientId String
  name        String   // "Piscine principale", "Spa"
  type        String   @default("pool") // pool | spa | both
  volume      Float?
  unit        String   @default("m3")
  shape       String?
  surface     String?  // liner, tile, concrete, etc.
  treatmentType String? // chlorine, salt, bromine, etc.
  saltSystem  Boolean  @default(false)
  filterType  String?  // sand, cartridge, etc.
  address     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client        ProClient       @relation(fields: [proClientId], references: [id], onDelete: Cascade)
  interventions ProIntervention[]
  waterTests    ProWaterTest[]

  @@index([proClientId])
}

// Un test d'eau effectué par le pro sur un bassin
model ProWaterTest {
  id          String   @id @default(cuid())
  proPoolId   String
  ph          Float?
  freeChlorine Float?
  totalChlorine Float?
  combinedChlorine Float?
  alkalinity  Float?
  calciumHardness Float?
  cyanuricAcid Float?
  salt        Float?
  phosphates  Float?
  temperature Float?
  clearWaterIndex Int?
  notes       String?
  testedAt    DateTime @default(now())

  pool        ProPool @relation(fields: [proPoolId], references: [id], onDelete: Cascade)

  @@index([proPoolId])
  @@index([testedAt])
}

// Une intervention du pro sur un bassin
model ProIntervention {
  id          String   @id @default(cuid())
  proClientId String
  proPoolId   String?
  technicianId String?  // User id du technicien
  type        String   @default("maintenance") // maintenance | repair | opening | closing | emergency
  status      String   @default("scheduled") // scheduled | in_progress | completed | cancelled
  scheduledAt DateTime
  completedAt DateTime?
  duration    Int?     // minutes
  notes       String?
  photos      String?  // JSON array of URLs (before/after)
  actions     String?  // JSON array of actions performed
  productsUsed String? // JSON array of products used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      ProClient @relation(fields: [proClientId], references: [id], onDelete: Cascade)
  pool        ProPool?  @relation(fields: [proPoolId], references: [id], onDelete: SetNull)

  @@index([proClientId])
  @@index([proPoolId])
  @@index([status])
  @@index([scheduledAt])
  @@index([technicianId])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA FAMILY — Partage de piscine familial (multi-user read/write access)
// ───────────────────────────────────────────────────────────────────────────
// A PoolShare grants another AQWELIA user access to a pool owned by someone
// else. Roles: owner (implicit, never stored), co_manager (can test/add data),
// viewer (read-only). Cascade-deleted when the pool OR either user is deleted.

model PoolShare {
  id           String   @id @default(cuid())
  poolId       String   // PoolProfile id
  sharedWithId String   // User id of the invited user
  role         String   @default("viewer") // owner | co_manager | viewer
  invitedBy    String   // User id of the owner who sent the invite
  createdAt    DateTime @default(now())

  pool        PoolProfile @relation(fields: [poolId], references: [id], onDelete: Cascade)
  sharedWith  User        @relation("PoolSharesSharedWith", fields: [sharedWithId], references: [id], onDelete: Cascade)
  invitedByUser User      @relation("PoolSharesOwnedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([poolId, sharedWithId])
  @@index([poolId])
  @@index([sharedWithId])
}

// ───────────────────────────────────────────────────────────────────────────
// AQWELIA HOME (IoT) — Capteurs connectés (ICO / iopool / ESPHome)
// ───────────────────────────────────────────────────────────────────────────
// Configuration of a connected water-quality sensor. Stores provider +
// credentials so the restock/automation engine can later poll the sensor API
// and inject a WaterTest. Sensitive fields (apiKey) are kept server-side only.

model IotSensor {
  id         String   @id @default(cuid())
  userId     String   // owner of the sensor config
  poolId     String?  // optional linked pool (null = global)
  provider   String   // ico | iopool | esphome | homeassistant
  label      String   // user-facing name
  deviceId   String?  // external id (ICO serial, iopool EcO id, HA entity id)
  apiUrl     String?  // base URL (esphome / HA / custom)
  apiKey     String?  // encrypted/secret token (server-side only)
  config     String?  // JSON blob with provider-specific options (refresh interval, MQTT topic…)
  status     String   @default("disconnected") // connected | disconnected | error
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([poolId])
}
